#!/usr/bin/env bash
# SessionStart hook for the prd-pipeline plugin.
# Plugins do not load CLAUDE.md / rules, so we inject a tiny router each session so the
# model knows the pipeline exists and when to route into it. The full procedure stays in
# the `prd-pipeline` skill and loads on demand (progressive disclosure).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
router_content=$(cat "${SCRIPT_DIR}/router.md" 2>&1 || echo "Error reading prd-pipeline router")

# Single-pass bash escaping for JSON embedding.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

router_escaped=$(escape_for_json "$router_content")
session_context="<EXTREMELY_IMPORTANT>\n${router_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0

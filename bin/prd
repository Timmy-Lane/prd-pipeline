#!/usr/bin/env bash
# prd — installer/manager for the prd-pipeline Claude Code skill + rule.
# Pure bash, no dependencies. Idempotent. macOS + Linux.
#
#   prd install                 install globally into ~/.claude (skill + rule + CLAUDE.md wiring + PATH)
#   prd install --project DIR   install just the skill into DIR/.claude/skills (commit with the repo)
#   prd update                  git pull (if a clone) + reinstall
#   prd uninstall               remove skill, rule, CLAUDE.md block, and the prd symlink
#   prd doctor                  show install status
set -euo pipefail

green(){ printf '\033[32m%s\033[0m\n' "$1"; }
dim(){ printf '\033[2m%s\033[0m\n' "$1"; }
err(){ printf '\033[31m%s\033[0m\n' "$1" >&2; }

# Resolve this script's real directory even when invoked through a symlink
# (portable: no GNU readlink -f). $0/BASH_SOURCE may be a symlink on PATH.
_resolve_dir() {
  local src="${BASH_SOURCE[0]}" dir
  while [ -h "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" && pwd
}
REPO_ROOT="$(cd "$(_resolve_dir)/.." && pwd)"
CLAUDE_HOME="${CLAUDE_HOME:-$HOME/.claude}"
SKILLS_DST="$CLAUDE_HOME/skills"
RULES_DST="$CLAUDE_HOME/rules/common"
CLAUDE_MD="$CLAUDE_HOME/CLAUDE.md"
BIN_DST="${PRD_BIN_DIR:-$HOME/.local/bin}"
MARK_START="<!-- prd-pipeline:start (managed by \`prd install\` — do not edit inside) -->"
MARK_END="<!-- prd-pipeline:end -->"
REPO_URL="${PRD_REPO_URL:-https://github.com/Timmy-Lane/prd-pipeline.git}"
case "$REPO_URL" in https://*) : ;; *) err "PRD_REPO_URL must be https:// (got: $REPO_URL)"; exit 1 ;; esac

block_text(){
  cat <<EOF
$MARK_START
## prd-pipeline (feature workflow)

\`/prd-pipeline\` — tier-routed entry point for any *build / add / implement*: spec/PRD → adversarial grill → confirmed plan-gate → parallel worktree build → verify → ship. Always start from \`main\`; the work auto-branches into isolated worktrees; you never switch branches. Always-on norm: \`rules/common/feature-workflow.md\`.
$MARK_END
EOF
}

wire_claude_md(){
  mkdir -p "$CLAUDE_HOME"
  if [ ! -f "$CLAUDE_MD" ]; then
    block_text > "$CLAUDE_MD"; dim "  created $CLAUDE_MD with prd-pipeline block"; return
  fi
  if grep -qF "prd-pipeline:start" "$CLAUDE_MD" && grep -qF "prd-pipeline:end" "$CLAUDE_MD"; then
    awk 'BEGIN{s=0} /^<!-- prd-pipeline:start/{s=1} s==0{print} /^<!-- prd-pipeline:end -->/{s=0}' "$CLAUDE_MD" \
      | awk 'NF{last=NR} {a[NR]=$0} END{for(i=1;i<=last;i++) print a[i]}' > "$CLAUDE_MD.tmp"
    printf '\n' >> "$CLAUDE_MD.tmp"; block_text >> "$CLAUDE_MD.tmp"
    mv "$CLAUDE_MD.tmp" "$CLAUDE_MD"; dim "  refreshed prd-pipeline block in CLAUDE.md"
  elif grep -qF "prd-pipeline:start" "$CLAUDE_MD"; then
    err "  WARNING: prd-pipeline:start present but :end marker missing — skipping CLAUDE.md edit to avoid truncation; fix the markers by hand"
  elif grep -qF "prd-pipeline" "$CLAUDE_MD"; then
    dim "  CLAUDE.md already mentions prd-pipeline (manual wiring) — left untouched"
  else
    printf '\n' >> "$CLAUDE_MD"; block_text >> "$CLAUDE_MD"; dim "  appended prd-pipeline block to CLAUDE.md"
  fi
}

symlink_cli(){
  mkdir -p "$BIN_DST"
  ln -sf "$REPO_ROOT/bin/prd" "$BIN_DST/prd"
  case ":$PATH:" in
    *":$BIN_DST:"*) : ;;
    *) dim "  note: $BIN_DST is not on PATH — add it, or call $BIN_DST/prd directly" ;;
  esac
}

cmd_install_global(){
  mkdir -p "$SKILLS_DST" "$RULES_DST"
  rm -rf "$SKILLS_DST/prd-pipeline"
  cp -R "$REPO_ROOT/skills/prd-pipeline" "$SKILLS_DST/"
  cp "$REPO_ROOT/VERSION" "$SKILLS_DST/prd-pipeline/VERSION" 2>/dev/null || true
  cp "$REPO_ROOT/rules/feature-workflow.md" "$RULES_DST/feature-workflow.md"
  wire_claude_md
  symlink_cli
  green "prd-pipeline installed."
  echo "  skill → $SKILLS_DST/prd-pipeline/   (invoke with /prd-pipeline)"
  echo "  rule  → $RULES_DST/feature-workflow.md   (auto-loads every session)"
  echo "  cli   → $BIN_DST/prd"
  check_deps
}

cmd_install_project(){
  local proj="${1:-}"
  [ -n "$proj" ] || { err "usage: prd install --project <path>"; exit 1; }
  [ -d "$proj" ] || { err "no such directory: $proj"; exit 1; }
  mkdir -p "$proj/.claude/skills"
  rm -rf "$proj/.claude/skills/prd-pipeline"
  cp -R "$REPO_ROOT/skills/prd-pipeline" "$proj/.claude/skills/"
  green "installed prd-pipeline skill into $proj/.claude/skills/  (commit it with the repo)."
  dim "  the feature-workflow rule stays global; project skills override global on conflict."
}

# ver_gt A B → exit 0 if A > B (numeric per-component; handles 0.10.0 > 0.9.0)
ver_gt() {
  local a="${1#v}" b="${2#v}"; [ "$a" = "$b" ] && return 1
  local IFS=. ; set -- $a; local a1=${1:-0} a2=${2:-0} a3=${3:-0}
  set -- $b; local b1=${1:-0} b2=${2:-0} b3=${3:-0}
  [ "$a1" -ne "$b1" ] 2>/dev/null && { [ "$a1" -gt "$b1" ]; return; }
  [ "$a2" -ne "$b2" ] 2>/dev/null && { [ "$a2" -gt "$b2" ]; return; }
  [ "$a3" -gt "$b3" ] 2>/dev/null
}

# Highest vX.Y.Z release tag from the remote (test seam: PRD_LSREMOTE_TAGS_FILE)
latest_remote_tag() {
  local raw
  if [ -n "${PRD_LSREMOTE_TAGS_FILE:-}" ]; then
    raw="$(cat "$PRD_LSREMOTE_TAGS_FILE" 2>/dev/null)"
  else
    raw="$(git ls-remote --tags "$REPO_URL" 2>/dev/null)"
  fi
  printf '%s\n' "$raw" \
    | grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+$' \
    | sed 's/^v//' | sort -t. -k1,1n -k2,2n -k3,3n | tail -1 || true
}

cmd_update_check() {
  local cur latest; cur="$(prd_version)"; latest="$(latest_remote_tag)"
  if [ -z "$latest" ]; then dim "  could not check for updates (offline?)"; return 0; fi
  if ver_gt "$latest" "$cur"; then
    green "  update available: v$cur → v$latest (run: prd update)"
  else
    green "  up to date (v$cur)"
  fi
}

cmd_update(){
  [ -d "$REPO_ROOT/.git" ] && { git -C "$REPO_ROOT" pull --ff-only || dim "  git pull skipped (no fast-forward / no upstream)"; }
  cmd_install_global
  green "updated."
}

cmd_uninstall(){
  rm -rf "$SKILLS_DST/prd-pipeline"
  rm -f "$RULES_DST/feature-workflow.md"
  [ -L "$BIN_DST/prd" ] && rm -f "$BIN_DST/prd"
  if [ -f "$CLAUDE_MD" ] && grep -qF "prd-pipeline:start" "$CLAUDE_MD" && grep -qF "prd-pipeline:end" "$CLAUDE_MD"; then
    awk 'BEGIN{s=0} /^<!-- prd-pipeline:start/{s=1} s==0{print} /^<!-- prd-pipeline:end -->/{s=0}' "$CLAUDE_MD" > "$CLAUDE_MD.tmp"
    mv "$CLAUDE_MD.tmp" "$CLAUDE_MD"; dim "  removed managed prd-pipeline block from CLAUDE.md"
  fi
  green "uninstalled (manual CLAUDE.md edits, if any, left intact)."
}

# Check the skills/tools prd-pipeline composes. git is REQUIRED (worktrees);
# the rest have built-in fallbacks but give the best experience when present.
check_deps(){
  echo "  dependencies:"
  if command -v git >/dev/null 2>&1; then green "    git            ok  (REQUIRED — worktree mandate)"; else err "    git            MISSING — REQUIRED for the worktree build; install git"; fi
  if grep -qsE '"superpowers@[^"]*": *true' "$CLAUDE_HOME/settings.json" 2>/dev/null \
     || ls "$CLAUDE_HOME"/plugins/cache/*/superpowers/*/skills/brainstorming/SKILL.md >/dev/null 2>&1; then
    green "    superpowers    ok  (brainstorming · writing-plans · dispatching-parallel-agents · TDD · verification · finishing-a-branch)"
  else
    dim  "    superpowers    missing — install the 'superpowers' plugin for the best composer; prd-pipeline still runs with built-in fallbacks"
  fi
  if find "$CLAUDE_HOME" -type d -iname deep-research 2>/dev/null | grep -q .; then
    green "    deep-research  ok  (research / grill engine)"
  else
    dim  "    deep-research  missing — falls back to the deep-researcher agent / web tools"
  fi
}

NOTIFY_CMD="$BIN_DST/prd notify --hook"   # absolute; hooks may run with minimal PATH
NOTIFY_MATCH="notify --hook"              # substring used to find/remove our hook

notify_hook_add() {
  local set="$CLAUDE_HOME/settings.json" tmp; tmp="$set.tmp.$$"
  mkdir -p "$CLAUDE_HOME"
  if python3 - "$set" "$NOTIFY_CMD" "$NOTIFY_MATCH" > "$tmp" <<'PY'
import json,sys,os
path,cmd,match=sys.argv[1],sys.argv[2],sys.argv[3]
data=json.load(open(path)) if (os.path.exists(path) and os.path.getsize(path)>0) else {}
ss=data.setdefault("hooks",{}).setdefault("SessionStart",[])
present=any(match in (h.get("command","")) for g in ss for h in g.get("hooks",[]))
if not present:
    grp=next((g for g in ss if g.get("matcher")=="startup"), None)
    if grp is None:
        grp={"matcher":"startup","hooks":[]}; ss.append(grp)
    grp.setdefault("hooks",[]).append({"type":"command","command":cmd,"timeout":10})
json.dump(data,sys.stdout,indent=2); sys.stdout.write("\n")
PY
  then mv "$tmp" "$set"
  else rm -f "$tmp"; err "  could not parse $set as JSON — left unchanged. Fix it, or add the hook by hand."; exit 1
  fi
}

notify_hook_remove() {
  local set="$CLAUDE_HOME/settings.json" tmp; tmp="$set.tmp.$$"
  [ -f "$set" ] || return 0
  if python3 - "$set" "$NOTIFY_MATCH" > "$tmp" <<'PY'
import json,sys,os
path,match=sys.argv[1],sys.argv[2]
data=json.load(open(path)) if os.path.getsize(path)>0 else {}
ss=data.get("hooks",{}).get("SessionStart",[])
for g in ss: g["hooks"]=[h for h in g.get("hooks",[]) if match not in (h.get("command",""))]
ss=[g for g in ss if g.get("hooks")]
if ss: data["hooks"]["SessionStart"]=ss
else:
    data.get("hooks",{}).pop("SessionStart",None)
    if data.get("hooks")=={}: data.pop("hooks",None)
json.dump(data,sys.stdout,indent=2); sys.stdout.write("\n")
PY
  then mv "$tmp" "$set"
  else rm -f "$tmp"; err "  could not parse $set as JSON — left unchanged."; exit 1
  fi
}

cmd_notify_hook() {
  local cache="$CLAUDE_HOME/.prd-update-cache" now last="" latest="" age=86400
  now="$(date +%s 2>/dev/null)" || exit 0
  last=""; latest=""
  if [ -f "$cache" ]; then IFS=$'\t' read -r last latest < "$cache" 2>/dev/null || true; fi
  case "${last:-}" in ''|*[!0-9]*) last=""; latest="" ;; esac   # corrupt/empty cache → treat as stale, refetch
  if [ -z "$last" ] || [ $((now - last)) -ge "$age" ]; then
    latest="$(latest_remote_tag)"
    [ -n "$latest" ] && printf '%s\t%s\n' "$now" "$latest" > "$cache" 2>/dev/null
  fi
  local cur; cur="$(prd_version)"
  if [ -n "${latest:-}" ] && ver_gt "$latest" "$cur"; then
    echo "prd-pipeline: update available v$cur → v$latest (run: prd update)"
  fi
  exit 0
}

cmd_notify() {
  case "${1:-}" in
    on)
      if ! command -v python3 >/dev/null 2>&1; then
        err "  prd notify needs python3 to edit settings.json safely. Add this SessionStart hook by hand:"
        dim "    {\"hooks\":{\"SessionStart\":[{\"matcher\":\"startup\",\"hooks\":[{\"type\":\"command\",\"command\":\"$NOTIFY_CMD\",\"timeout\":10}]}]}}"
        exit 1
      fi
      notify_hook_add
      green "  prd notify enabled (opt-in SessionStart nudge, <=1 network check/day)." ;;
    off)
      if ! command -v python3 >/dev/null 2>&1; then err "  prd notify off needs python3"; exit 1; fi
      notify_hook_remove; green "  prd notify disabled." ;;
    --hook) cmd_notify_hook ;;
    ""|status)
      if grep -qsF "$NOTIFY_MATCH" "$CLAUDE_HOME/settings.json" 2>/dev/null; then echo "  notify: on"; else echo "  notify: off"; fi ;;
    *) err "usage: prd notify {on|off|status}"; exit 1 ;;
  esac
}

spec_template() {
  if [ -f "$REPO_ROOT/skills/prd-pipeline/references/spec-template.md" ]; then
    echo "$REPO_ROOT/skills/prd-pipeline/references/spec-template.md"
  else
    echo "$SKILLS_DST/prd-pipeline/references/spec-template.md"
  fi
}

cmd_new() {
  local topic="${1:-}"
  [ -n "$topic" ] || { err "usage: prd new <topic-kebab-case>"; exit 1; }
  case "$topic" in
    *[!a-z0-9-]*|-*|*-) err "topic must be lowercase kebab-case [a-z0-9-], not starting/ending with '-'"; exit 1 ;;
  esac
  local dir="docs/specs"; mkdir -p "$dir"
  local last n
  last="$(ls "$dir" 2>/dev/null | sed -n 's/^\([0-9]\{4\}\)-.*/\1/p' | sort -n | tail -1)"
  n="$(printf '%04d' "$(( 10#${last:-0} + 1 ))")"
  local tmpl out today; tmpl="$(spec_template)"; out="$dir/$n-$topic.md"; today="$(date +%Y-%m-%d)"
  [ -f "$tmpl" ] || { err "spec template not found ($tmpl)"; exit 1; }
  sed -e "s/^id: NNNN/id: $n/" \
      -e "s/^title: <kebab-case-title>/title: $topic/" \
      -e "s/^created: <YYYY-MM-DD>/created: $today/" "$tmpl" > "$out"
  green "created $out"
}

# ---------------------------------------------------------------------------
# Spec corpus helpers (shared by list + audit). Frontmatter is parsed the same
# way cmd_new does — first matching line, trailing "# comment" + ws stripped.
# Specs are append-only (SKILL.md); nothing here deletes, renames, or archives.
# ---------------------------------------------------------------------------
SPEC_DIR="docs/specs"
VALID_STATUS="draft accepted implemented superseded abandoned"

spec_field() {  # spec_field FILE KEY -> value (trailing comment + surrounding ws stripped)
  sed -n "s/^$2: *//p" "$1" 2>/dev/null | head -1 | sed -e 's/[[:space:]]*#.*//' -e 's/[[:space:]]*$//'
}
spec_status() { spec_field "$1" status | tr -d '[:space:]'; }   # single token
is_valid_status() { case " $VALID_STATUS " in *" $1 "*) return 0 ;; *) return 1 ;; esac; }

# YYYY-MM-DD -> epoch seconds (GNU `date -d` + BSD `date -j`); empty on failure.
# Probe with a concrete BSD `-j -f` parse of a fixed date (GNU date has no -j) rather
# than relying on bare `date -j`, whose no-arg behaviour is version-dependent.
date_to_epoch() {
  if date -j -f '%Y-%m-%d' '1970-01-01' +%s >/dev/null 2>&1; then
    date -j -f '%Y-%m-%d' "$1" +%s 2>/dev/null   # BSD / macOS
  else
    date -d "$1" +%s 2>/dev/null                  # GNU / Linux
  fi
}
days_since() {  # YYYY-MM-DD -> whole days until today; nonzero/empty if uncomputable
  local d="$1" now t0
  case "$d" in [0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9]) ;; *) return 1 ;; esac
  now="$(date +%s 2>/dev/null)" || return 1
  t0="$(date_to_epoch "$d")" || t0=""
  [ -n "$t0" ] || return 1
  echo $(( (now - t0) / 86400 ))
}

cmd_list() {
  local want_status=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --status) shift; [ $# -gt 0 ] || { err "usage: prd list --status <status>"; exit 1; }; want_status="$1" ;;
      --status=*) want_status="${1#*=}" ;;
      *) err "usage: prd list [--status <status>]"; exit 1 ;;
    esac
    shift
  done
  local dir="$SPEC_DIR"
  [ -d "$dir" ] || { dim "  no $dir/ in $(pwd)"; return 0; }
  local f status any=0
  local total=0 c_draft=0 c_accepted=0 c_implemented=0 c_abandoned=0 c_superseded=0 c_invalid=0
  for f in "$dir"/*.md; do
    [ -f "$f" ] || continue
    any=1; total=$((total+1)); status="$(spec_status "$f")"
    case "$status" in
      draft)       c_draft=$((c_draft+1)) ;;
      accepted)    c_accepted=$((c_accepted+1)) ;;
      implemented) c_implemented=$((c_implemented+1)) ;;
      abandoned)   c_abandoned=$((c_abandoned+1)) ;;
      superseded)  c_superseded=$((c_superseded+1)) ;;
      *)           c_invalid=$((c_invalid+1)) ;;
    esac
  done
  if [ "$any" != 1 ]; then dim "  no specs in $dir/"; return 0; fi
  local filt=""; [ -n "$want_status" ] && filt="  (showing: $want_status)"
  printf '  specs in %s/ — total:%d  draft:%d  accepted:%d  implemented:%d  abandoned:%d  superseded:%d  invalid:%d%s\n' \
    "$dir" "$total" "$c_draft" "$c_accepted" "$c_implemented" "$c_abandoned" "$c_superseded" "$c_invalid" "$filt"
  local id title
  for f in "$dir"/*.md; do
    [ -f "$f" ] || continue
    status="$(spec_status "$f")"
    [ -z "$want_status" ] || [ "$status" = "$want_status" ] || continue
    id="$(spec_field "$f" id)"; title="$(spec_field "$f" title)"
    printf '  %-6s %-28s %s\n' "${id:-?}" "${title:-?}" "${status:-?}"
  done
}

# prd audit — read-only spec-lifecycle consistency check. Exits 1 if any ERROR.
# --fix applies only the one safe metadata fix (missing status: -> draft, [y/N]);
# everything else prints a suggested manual action. Never deletes/renames.
cmd_audit() {
  local fix=0 json=0 stale_days=30
  while [ $# -gt 0 ]; do
    case "$1" in
      --fix) fix=1 ;;
      --json) json=1 ;;
      --stale-days) shift; [ $# -gt 0 ] || { err "--stale-days needs a value"; exit 1; }; stale_days="$1" ;;
      --stale-days=*) stale_days="${1#*=}" ;;
      -h|--help) echo "usage: prd audit [--fix] [--json] [--stale-days N]"; return 0 ;;
      *) err "unknown audit flag: $1 (try: prd audit --help)"; exit 1 ;;
    esac
    shift
  done
  case "$stale_days" in ''|*[!0-9]*) err "--stale-days needs a non-negative integer"; exit 1 ;; esac

  local dir="$SPEC_DIR"
  if [ ! -d "$dir" ]; then
    if [ "$json" = 1 ]; then echo "[]"; else dim "  no $dir/ in $(pwd)"; fi
    return 0
  fi

  # git is optional here; desync checks degrade gracefully when absent
  local have_git=0 branches=""
  if command -v git >/dev/null 2>&1 && git rev-parse --git-dir >/dev/null 2>&1; then
    have_git=1
    branches="$(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null || true)"
  fi

  # findings: SEVERITY|FILE|CODE|MESSAGE (one per line). idx: ID|STATUS|FILE.
  local findings="" errors=0 warns=0
  add_finding() {  # sev file code msg
    findings="$findings$1|$2|$3|$4
"
    case "$1" in ERROR) errors=$((errors+1)) ;; WARN) warns=$((warns+1)) ;; esac
  }

  local f idx="" id status
  for f in "$dir"/*.md; do
    [ -f "$f" ] || continue
    id="$(spec_field "$f" id)"; status="$(spec_status "$f")"
    idx="$idx$id|$status|$f
"
  done
  local dup
  dup="$(printf '%s' "$idx" | awk -F'|' '$1!=""{print $1}' | sort | uniq -d)"

  local base fnum title sup tgt_status created days
  for f in "$dir"/*.md; do
    [ -f "$f" ] || continue
    base="$(basename "$f")"; fnum="${base%%-*}"
    id="$(spec_field "$f" id)"; title="$(spec_field "$f" title)"
    status="$(spec_status "$f")"; sup="$(spec_field "$f" supersedes)"

    # structure / vocabulary / dupes
    if [ -z "$status" ]; then
      add_finding ERROR "$f" missing-status "no status: field (lifecycle machinery degrades to a manual list)"
    elif ! is_valid_status "$status"; then
      add_finding ERROR "$f" invalid-status "status '$status' not in {$VALID_STATUS}"
    fi
    [ -n "$id" ]    || add_finding ERROR "$f" missing-id    "no id: field"
    [ -n "$title" ] || add_finding ERROR "$f" missing-title "no title: field"
    if [ -n "$id" ] && [ -n "$fnum" ] && [ "$id" != "$fnum" ]; then
      add_finding ERROR "$f" id-filename-mismatch "id:$id != filename prefix $fnum (rename the file or fix id:)"
    fi
    if [ -n "$id" ] && printf '%s\n' "$dup" | grep -qx "$id"; then
      add_finding ERROR "$f" duplicate-id "id:$id is used by more than one spec"
    fi

    # referential integrity (append-only: superseded/abandoned link forward)
    if [ "$status" = superseded ] && [ -z "$sup" ]; then
      add_finding ERROR "$f" superseded-no-link "status superseded but supersedes: is empty (add the id it replaces)"
    fi
    if [ -n "$sup" ]; then
      if ! printf '%s' "$idx" | awk -F'|' '{print $1}' | grep -qx "$sup"; then
        add_finding ERROR "$f" supersedes-dangling "supersedes:$sup has no matching spec"
      else
        tgt_status="$(printf '%s' "$idx" | awk -F'|' -v t="$sup" '$1==t{print $2; exit}')"
        if [ -n "$tgt_status" ] && [ "$tgt_status" != superseded ]; then
          add_finding WARN "$f" supersede-target-live "supersedes:$sup but $sup is still '$tgt_status', not superseded"
        fi
      fi
    fi

    # git desync — only the valid polarity (branch alive but status not advanced).
    # "implemented but no branch" is the SUCCESS state (workflow deletes merged
    # branches), so we verify an implemented claim via the body marker instead.
    if [ "$have_git" = 1 ] && [ -n "$id" ]; then
      if printf '%s\n' "$branches" | grep -qE "^feat/$id([/-]|$)"; then
        case "$status" in
          draft|accepted) add_finding WARN "$f" branch-ahead-of-status "feat/$id-* branch exists but spec still '$status' (bump the status?)" ;;
        esac
      fi
    fi
    if [ "$status" = implemented ] && ! grep -qF '**Implemented' "$f"; then
      add_finding WARN "$f" implemented-no-marker "status implemented but no '> **Implemented ...**' marker in the body (unverified claim)"
    fi

    # staleness — a draft/accepted spec left dangling
    case "$status" in
      draft|accepted)
        created="$(spec_field "$f" created)"
        if [ -n "$created" ]; then
          days="$(days_since "$created" 2>/dev/null || true)"
          if [ -n "$days" ] && [ "$days" -gt "$stale_days" ] 2>/dev/null; then
            add_finding WARN "$f" stale "status '$status' and $days days old (> $stale_days; pick it up or abandon it)"
          fi
        fi
        ;;
    esac

    # the one safe auto-fix: a spec with frontmatter but no status: line -> draft
    if [ "$fix" = 1 ] && [ -z "$status" ] && head -1 "$f" | grep -q '^---[[:space:]]*$'; then
      printf '  fix %s: insert "status: draft" after the opening --- ? [y/N] ' "$f" >&2
      local ans; read -r ans || ans=""
      case "$ans" in
        y|Y) awk 'BEGIN{n=0} /^---[[:space:]]*$/{n++; print; if(n==1) print "status: draft"; next} {print}' "$f" > "$f.tmp" \
               && mv "$f.tmp" "$f" && green "  fixed $f (status: draft)" \
               || { rm -f "$f.tmp"; err "  fix failed for $f"; } ;;
        *) dim "  skipped $f" ;;
      esac
    fi
  done

  if [ "$json" = 1 ]; then
    printf '['
    printf '%s' "$findings" | { first=1; while IFS='|' read -r sev file code msg; do
      [ -n "$sev" ] || continue
      [ "$first" = 1 ] || printf ','
      first=0
      ef="$(printf '%s' "$file" | sed 's/\\/\\\\/g; s/"/\\"/g')"
      em="$(printf '%s' "$msg"  | sed 's/\\/\\\\/g; s/"/\\"/g')"
      printf '{"severity":"%s","file":"%s","code":"%s","message":"%s"}' "$sev" "$ef" "$code" "$em"
    done; }
    printf ']\n'
  elif [ -z "$findings" ]; then
    green "  prd audit: ok (no issues)"
  else
    printf '%s' "$findings" | while IFS='|' read -r sev file code msg; do
      [ -n "$sev" ] || continue
      case "$sev" in
        ERROR) printf '  \033[31mERROR\033[0m %s — %s\n' "$file" "$msg" ;;
        WARN)  printf '  \033[33mWARN\033[0m  %s — %s\n' "$file" "$msg" ;;
      esac
    done
    printf '  %d error(s), %d warning(s)\n' "$errors" "$warns"
  fi
  [ "$errors" -gt 0 ] && return 1 || return 0
}

prd_version() { tr -d '[:space:]' < "$REPO_ROOT/VERSION" 2>/dev/null; }
cmd_version() { local v; v="$(prd_version)"; echo "${v:-unknown}"; }

cmd_doctor(){
  echo "prd-pipeline doctor"
  echo "  repo:        $REPO_ROOT"
  echo "  claude home: $CLAUDE_HOME"
  local clone_v inst_v
  clone_v="$(prd_version)"
  inst_v=""
  [ -f "$SKILLS_DST/prd-pipeline/VERSION" ] && inst_v="$(tr -d '[:space:]' < "$SKILLS_DST/prd-pipeline/VERSION")"
  echo "  version (clone):     ${clone_v:-unknown}"
  echo "  version (installed): ${inst_v:-not installed}"
  if [ -n "$clone_v" ] && [ -n "$inst_v" ] && [ "$clone_v" != "$inst_v" ]; then
    err "  drift: installed skill v$inst_v differs from clone v$clone_v — run: prd install"
  fi
  [ -f "$SKILLS_DST/prd-pipeline/SKILL.md" ] && green "  skill:       installed" || echo "  skill:       NOT installed (run: prd install)"
  [ -f "$RULES_DST/feature-workflow.md" ]    && green "  rule:        installed" || echo "  rule:        NOT installed (run: prd install)"
  if [ -f "$CLAUDE_MD" ] && grep -qiF "prd-pipeline" "$CLAUDE_MD"; then green "  CLAUDE.md:   wired"; else echo "  CLAUDE.md:   not wired"; fi
  [ -L "$BIN_DST/prd" ] && green "  cli on PATH: $BIN_DST/prd" || echo "  cli on PATH: no symlink (run: prd install)"
  check_deps
}

main(){
  local sub="${1:-}"; shift || true
  case "$sub" in
    install)
      if [ "${1:-}" = "--project" ]; then cmd_install_project "${2:-}"; else cmd_install_global; fi ;;
    update)    if [ "${1:-}" = "--check" ]; then cmd_update_check; else cmd_update; fi ;;
    uninstall) cmd_uninstall ;;
    doctor)    cmd_doctor ;;
    notify)    cmd_notify "$@" ;;
    new)       cmd_new "$@" ;;
    list)      cmd_list "$@" ;;
    audit)     cmd_audit "$@" ;;
    version|--version|-v) cmd_version ;;
    ""|-h|--help|help)
      cat <<'USAGE'
usage: prd <command>
  install [--project DIR]   install globally (or just the skill into DIR)
  update [--check]          git pull + reinstall  (update --check: report newer release, no pull)
  uninstall                 remove skill, rule, CLAUDE.md block, symlink
  doctor                    show install status + versions (clone vs installed)
  version                   print the prd-pipeline version
  notify {on|off|status}    opt-in SessionStart update nudge (<=1 network check/day)
  new <topic>               scaffold docs/specs/NNNN-<topic>.md from the template
  list [--status S]         list specs + count summary (filter rows by status)
  audit [--fix] [--json]    check spec-lifecycle consistency (--stale-days N; --fix: safe metadata only)
USAGE
      ;;
    *) err "unknown command: $sub"; err "run: prd --help"; exit 1 ;;
  esac
}
main "$@"
